rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function familyData(familyId) {
      return get(/databases/$(database)/documents/families/$(familyId)).data;
    }

    function familyExists(familyId) {
      return exists(/databases/$(database)/documents/families/$(familyId));
    }

    // members 배열에 UID(문자열)가 포함되어 있는지 확인
    function isMember(familyId) {
      return signedIn()
        && familyExists(familyId)
        && request.auth.uid in familyData(familyId).members;
    }

    function isOwner(familyId) {
      return signedIn()
        && familyExists(familyId)
        && familyData(familyId).ownerId == request.auth.uid;
    }

    match /families/{familyId} {
      // 단건 조회: 초대 가입 전 familyId 확인용
      allow get: if signedIn();
      // 쿼리(array-contains): resource.data 직접 비교 (get() 없이)
      allow list: if signedIn()
        && request.auth.uid in resource.data.members;

      allow create: if signedIn()
        && request.resource.data.ownerId == request.auth.uid
        && request.auth.uid in request.resource.data.members;

      allow update: if signedIn() && (
        (
          !(request.auth.uid in resource.data.members)
          && request.auth.uid in request.resource.data.members
        )
        ||
        (
          request.auth.uid in resource.data.members
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['memberNames', 'memberLastSeen'])
        )
        ||
        isOwner(familyId)
      );

      allow delete: if isOwner(familyId);
    }

    match /transactions/{txId} {
      allow read: if signedIn()
        && resource.data.familyId is string
        && isMember(resource.data.familyId);

      allow create: if signedIn()
        && request.resource.data.familyId is string
        && isMember(request.resource.data.familyId)
        && request.resource.data.memberId == request.auth.uid;

      allow update, delete: if signedIn()
        && resource.data.familyId is string
        && isMember(resource.data.familyId);
    }

    match /fixedTransactions/{fixedId} {
      allow read: if signedIn()
        && resource.data.familyId is string
        && isMember(resource.data.familyId);

      allow create: if signedIn()
        && request.resource.data.familyId is string
        && isMember(request.resource.data.familyId)
        && request.resource.data.memberId == request.auth.uid;

      allow update, delete: if signedIn()
        && resource.data.familyId is string
        && isMember(resource.data.familyId);
    }

    match /invitations/{code} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.familyId is string
        && isMember(request.resource.data.familyId);
      allow delete: if signedIn()
        && resource.data.familyId is string
        && isMember(resource.data.familyId);
    }
  }
}
